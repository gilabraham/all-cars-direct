# Copy to `.streamlit/secrets.toml` for local dev (the real file is gitignored).
# On Streamlit Community Cloud, paste these same lines into
# Settings → Secrets in the app dashboard — DO NOT commit secrets to the repo.

# Admin password — required to access /admin and all back-office pages.
# Generate a strong one, e.g. `python -c "import secrets; print(secrets.token_urlsafe(16))"`.
admin_password = "change-me-to-something-strong"

# --- Optional: SMTP for the "Request this deal" emails ---
# If these aren't set the inquiry is still saved to the DB; the customer just
# won't get a confirmation email.
# smtp_host = "smtp.gmail.com"
# smtp_port = 587
# smtp_user = "info@allcarsdirectllc.com"
# smtp_password = "app-password-from-google"
# smtp_from = "All Cars Direct <info@allcarsdirectllc.com>"
# admin_email = "info@allcarsdirectllc.com"
